{
  "include": [
    "vite.config.*",
    "vitest.config.*",
    "cypress.config.*",
    "nightwatch.conf.*",
    "playwright.config.*",
    "env.d.ts", 
    "src/**/*", 
    "src/**/*.vue"
  ],
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "exclude": ["src/**/__tests__/*"],
  "files": [],
  
  "compilerOptions": {
    "composite": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "types": ["bun"],
    "paths": {
      "@/*": ["./src/*"]
    },
    "lib": [
        "DOM",
        "DOM.Iterable",
        "ESNext.Collection",
        "ESNext.Array",
        "ESNext"
    ],
  }
}
