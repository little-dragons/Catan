{
    "compilerOptions": {
        "composite": true,
        "sourceMap": true,
        "declarationMap": true,
        "target": "ESNext",
        "module": "ESNext",
        "lib": [
            "ESNext.Collection",
            "ESNext.Array",
            "ESNext"
        ],
        "moduleResolution": "Bundler",
        "outDir": "../dist/shared",
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "strict": true,
        "skipLibCheck": true,
        "types": ["bun"]
    }
}
