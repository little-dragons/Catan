{
  "name": "catan-server",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "NODE_ENV=development bun --hot Server.ts",
    "prod": "NODE_ENV=productionbun Server.ts",
    "migrate-dev": "NODE_ENV=development bun database/MigrationsExecutor.ts && bun run generate-types-dev",
    "migrate-prod": "NODE_ENV=productionbun database/MigrationsExecutor.ts && bun run generate-types-prod",
    "remigrate-dev": "NODE_ENV=development bun database/MigrationsExecutor.ts -remigrate && bun run generate-types-dev",
    "force-remigrate-prod": "NODE_ENV=productionbun database/MigrationsExecutor.ts -remigrate && bun run generate-types-prod",
    "generate-types-dev": "NODE_ENV=development kysely-codegen --dialect sqlite --out-file database/DBTypes.d.ts",
    "generate-types-prod": "NODE_ENV=production kysely-codegen --dialect sqlite --out-file database/DBTypes.d.ts"
  },
  "devDependencies": {
    "@types/bcrypt": "catalog:shared",
    "@types/bun": "catalog:shared",
    "@types/uuid": "catalog:shared",
    "kysely-codegen": "catalog:backend"
  },
  "dependencies": {
    "@socket.io/admin-ui": "catalog:backend",
    "bcrypt": "catalog:shared",
    "better-sqlite3": "catalog:backend",
    "catan-shared": "link:catan-shared",
    "kysely": "catalog:backend",
    "kysely-bun-sqlite": "catalog:backend",
    "socket.io": "catalog:shared",
    "typescript": "catalog:shared",
    "uuid": "catalog:shared"
  }
}
